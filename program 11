#include <stdio.h>

int n, graph[10][10], visited[10];

void dfs(int s)
{
    int i;

    visited[s]=1;
    printf("q%d ",s);

    for(i=0;i<n;i++)
    {
        if(graph[s][i] && !visited[i])
            dfs(i);
    }
}

int main()
{
    int i,j;

    printf("Enter number of states: ");
    scanf("%d",&n);

    printf("Enter epsilon transition matrix:\n");

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
            visited[j]=0;

        printf("\nEpsilon Closure(q%d) = { ",i);
        dfs(i);
        printf("}");
    }

    return 0;
}
